# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL password (used by docker-compose and the app)
POSTGRES_PASSWORD=change-this-password

# Full connection string (overrides individual settings)
PPE_DATABASE_URL=postgresql://ppe_user:change-this-password@localhost:5432/ppe_db

# ── Model ──────────────────────────────────────────────────────────────────────
PPE_MODEL_PATH=best.pt
PPE_CONF_THRESHOLD=0.5

# ── API ────────────────────────────────────────────────────────────────────────
PPE_API_HOST=0.0.0.0
PPE_API_PORT=8000

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
