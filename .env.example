# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL password (used by docker-compose and the app)
POSTGRES_PASSWORD=change-this-password

# Full connection string (overrides individual settings)
PPE_DATABASE_URL=postgresql://ppe_user:change-this-password@localhost:5432/ppe_db

# ── Model ──────────────────────────────────────────────────────────────────────
PPE_MODEL_PATH=best.pt
PPE_CONF_THRESHOLD=0.5

# ── API ────────────────────────────────────────────────────────────────────────
PPE_API_HOST=0.0.0.0
PPE_API_PORT=8000

# ── Alerts ─────────────────────────────────────────────────────────────────────
# Create at: Slack → Apps → Incoming Webhooks → Add New Webhook
PPE_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
# Fire alert after this many seconds of continuous violation (default: 30)
PPE_ALERT_VIOLATION_SECS=30

# ── Observability ──────────────────────────────────────────────────────────────
# Grafana admin password (default: admin — change in production)
GRAFANA_PASSWORD=change-this-password

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
